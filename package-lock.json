function App() {

  const board = [
    ["SI","PE","TA","MB","BG","SF","SI","PE","TA"],
    ["PE","TA","MB","BG","SF","SI","PE","TA","MB"],
    ["TA","MB","BG","SF","SI","PE","TA","MB","BG"],
    ["MB","BG","SF","SI","PE","TA","MB","BG","SF"],
    ["BG","SF","SI","PE","TA","MB","BG","SF","SI"],
    ["SF","SI","PE","TA","MB","BG","SF","SI","PE"],
    ["SI","PE","TA","MB","BG","SF","SI","PE","TA"],
    ["PE","TA","MB","BG","SF","SI","PE","TA","MB"],
    ["TA","MB","BG","SF","SI","PE","TA","MB","BG"],
  ];

  const catImages = {
    SI: require("./cats/SI.jpg"),
    PE: require("./cats/PE.jpg"),
    TA: require("./cats/TA.jpg"),
    MB: require("./cats/MB.jpg"),
    BG: require("./cats/BG.jpg"),
    SF: require("./cats/SF.jpg"),
  };

  return (
    <div style={{
      display: "flex",
      flexDirection: "column",
      alignItems: "center",
      backgroundColor: "#fff0f5",
      minHeight: "100vh",
      padding: "20px",
    }}>

      <h1 style={{ color: "#ff85b3", fontSize: "32px" }}>
        Cat Consensus
      </h1>

      <div style={{
        display: "grid",
        gridTemplateColumns: "repeat(9, 60px)",
        gap: "6px",
        backgroundColor: "#ffe0ef",
        padding: "16px",
        borderRadius: "20px",
      }}>
        {board.map((row, r) =>
          row.map((code, c) => (
            <div
              key={r + c}
              style={{
                width: "60px",
                height: "60px",
                borderRadius: "10px",
                overflow: "hidden",
                border: "2px solid #ffb7d5",
              }}
            >
              <img
                src={catImages[code]}
                alt={code}
                style={{
                  width: "100%",
                  height: "100%",
                  objectFit: "cover",
                }}
              />
            </div>
          ))
        )}
      </div>

    </div>
  );
}

export default App;